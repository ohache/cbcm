  "advice": [
    {
      "id": "zona-segura",
      "order": 10,
      "title": "Permanecer en zona segura",
      "text": "Indique al alertante que permanezca en una zona segura, alejada del fuego, el humo y de cualquier otro riesgo presente.",
      "source": "CERO 5.3.0.2, pp. 6–7"
    },
    {
      "id": "no-exponerse",
      "order": 20,
      "title": "No exponerse",
      "text": "Indique al alertante que no se exponga al fuego o al humo, ni intente un rescate que ponga en riesgo su propia seguridad.",
      "source": "CERO 5.3.0.1–2, pp. 6–7"
    },
    {
      "id": "mantener-contacto",
      "order": 30,
      "title": "Mantener una vía de comunicación",
      "text": "Confirme un teléfono de contacto y mantenga disponible una vía de comunicación con un testigo del suceso.",
      "source": "CERO 5.2.1.2, p. 5"
    },
    {
      "id": "persona-atrapada",
      "order": 40,
      "title": "Persona atrapada",
      "text": "Indique a la persona atrapada que vaya a la habitación más alejada del incendio que tenga una ventana a la vía pública, cierre la puerta, coloque un trapo o una toalla húmedos en la puerta para limitar la entrada de humo y se haga visible desde la ventana.",
      "source": "Revisión del MVP"
    },
    {
      "id": "refugio-humo",
      "order": 50,
      "title": "Humo en la escalera",
      "text": "Si no pueden evacuar con seguridad por el humo, indique que se refugien en la habitación más alejada con ventana al exterior, cierren las puertas y coloquen toallas húmedas bajo la puerta para limitar la entrada de humo.",
      "source": "Interrogatorios · Incendio de Vivienda"
    },
    {
      "id": "evacuacion-sin-humo",
      "order": 60,
      "title": "Evacuación sin humo en la escalera",
      "text": "Si la salida es segura, indique que abandonen la zona agachados, protejan nariz y boca, no utilicen el ascensor, no abran puertas ni ventanas innecesariamente y cierren la puerta principal al salir.",
      "source": "Interrogatorios · Incendio de Vivienda"
    },
    {
      "id": "no-regresar",
      "order": 70,
      "title": "No regresar a la vivienda",
      "text": "Una vez fuera, indique que no vuelvan a entrar en la vivienda y que esperen la llegada de los servicios de emergencia en una zona segura.",
      "source": "Revisión del MVP"
    },
    {
      "id": "extincion-segura",
      "order": 80,
      "title": "Intento de extinción",
      "text": "Solo si puede hacerse sin peligro: no usar agua sobre elementos eléctricos ni aceite; si se utiliza un extintor, dirigirlo a la base de las llamas.",
      "source": "Interrogatorios · Incendio de Vivienda"
    },
    {
      "id": "alejarse-estructura",
      "order": 90,
      "title": "Riesgo de derrumbamiento",
      "text": "Indique al alertante que se aleje de la edificación y de cualquier elemento que pueda caer, manteniéndose en una zona segura.",
      "source": "Interrogatorios · Incendio de Vivienda; CERO 5.3"
    }
  ],
