  "advice": [
    {
      "id": "zona-segura",
      "order": 10,
      "title": "Permanecer en zona segura",
      "text": "Indique al alertante que permanezca en una zona segura, alejada del fuego, el humo y de cualquier otro riesgo presente.",
      "source": "CERO 5.3.0.2, pp. 6–7"
    },
    {
      "id": "no-exponerse",
      "order": 20,
      "title": "No exponerse",
      "text": "Indique al alertante que no se exponga al fuego o al humo, ni intente un rescate que ponga en riesgo su propia seguridad.",
      "source": "CERO 5.3.0.1–2, pp. 6–7"
    },
    {
      "id": "mantener-contacto",
      "order": 30,
      "title": "Mantener una vía de comunicación",
      "text": "Confirme un teléfono de contacto y mantenga disponible una vía de comunicación con un testigo del suceso.",
      "source": "CERO 5.2.1.2, p. 5"
    },
